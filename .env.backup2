# Database - HostGator
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=helde663_pagby
DB_USERNAME=helde663_admin
DB_PASSWORD=Jamapar@55


# Domínio para tenants em produção
TENANT_DOMAIN_SUFFIX=.pagby.com.br

# Paths específicos do HostGator
