HOSTGATOR_STORAGE_PATH=/home4/helde663/pagby/storage

# Configuração da conexão tenant
TENANT_DB_HOST=localhost
TENANT_DB_USERNAME=helde663_admin
TENANT_DB_PASSWORD=Jamapar@55


SESSION_DRIVER=file
SESSION_STORE=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_EXPIRE_ON_CLOSE=true
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=tenant
